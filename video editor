import React, { useState, useRef, useEffect, useCallback } from 'react';
import { motion, AnimatePresence, Reorder } from 'framer-motion';

// Video Editor Component - CapCut/Premiere Pro Style
export default function VideoEditor() {
  // Core State
  const [project, setProject] = useState({
    name: 'Untitled Project',
    duration: 30,
    width: 1920,
    height: 1080,
    fps: 30,
  });
  
  const [timeline, setTimeline] = useState({
    zoom: 100,
    playhead: 0,
    isPlaying: false,
    playbackRate: 1,
    loop: false,
    snapEnabled: true,
  });
  
  const [tracks, setTracks] = useState([
    { id: 'video-1', type: 'video', name: 'Video 1', locked: false, muted: false, visible: true, height: 100, clips: [] },
    { id: 'video-2', type: 'video', name: 'Video 2', locked: false, muted: false, visible: true, height: 100, clips: [] },
    { id: 'audio-1', type: 'audio', name: 'Audio 1', locked: false, muted: false, visible: true, height: 60, clips: [] },
    { id: 'audio-2', type: 'audio', name: 'Audio 2', locked: false, muted: false, visible: true, height: 60, clips: [] },
    { id: 'text-1', type: 'text', name: 'Text', locked: false, muted: false, visible: true, height: 60, clips: [] },
    { id: 'effects-1', type: 'effects', name: 'Effects', locked: false, muted: false, visible: true, height: 60, clips: [] },
  ]);
  
  const [selectedClip, setSelectedClip] = useState(null);
  const [selectedTrack, setSelectedTrack] = useState(null);
  const [activePanel, setActivePanel] = useState('media');
  const [mediaLibrary, setMediaLibrary] = useState([]);
  const [effectsLibrary, setEffectsLibrary] = useState([]);
  const [transitionsLibrary, setTransitionsLibrary] = useState([]);
  const [textTemplates, setTextTemplates] = useState([]);
  const [filters, setFilters] = useState([]);
  const [appliedFilters, setAppliedFilters] = useState([]);
  const [history, setHistory] = useState([]);
  const [historyIndex, setHistoryIndex] = useState(-1);
  const [showExport, setShowExport] = useState(false);
  const [exportProgress, setExportProgress] = useState(0);
  const [isExporting, setIsExporting] = useState(false);
  const [notification, setNotification] = useState(null);
  const [showSettings, setShowSettings] = useState(false);
  const [showShortcuts, setShowShortcuts] = useState(false);
  const [fullscreen, setFullscreen] = useState(false);
  const [previewZoom, setPreviewZoom] = useState(100);
  const [colorGrading, setColorGrading] = useState({
    brightness: 100,
    contrast: 100,
    saturation: 100,
    temperature: 0,
    tint: 0,
    highlights: 0,
    shadows: 0,
    whites: 0,
    blacks: 0,
  });
  const [audioLevels, setAudioLevels] = useState({ master: 100, music: 80, sfx: 70, voice: 90 });
  const [draggedItem, setDraggedItem] = useState(null);
  const [trimmingClip, setTrimmingClip] = useState(null);
  const [trimmingSide, setTrimmingSide] = useState(null);
  const [splitPoint, setSplitPoint] = useState(null);
  const [showColorPanel, setShowColorPanel] = useState(false);
  const [showAudioPanel, setShowAudioPanel] = useState(false);
  const [currentWorkspace, setCurrentWorkspace] = useState('edit');
  const [workspaces] = useState([
    { id: 'edit', name: 'Edit', icon: '✂️' },
    { id: 'color', name: 'Color', icon: '🎨' },
    { id: 'audio', name: 'Audio', icon: '🎵' },
    { id: 'effects', name: 'Effects', icon: '✨' },
    { id: 'export', name: 'Export', icon: '📤' },
  ]);

  // Refs
  const canvasRef = useRef(null);
  const videoRef = useRef(null);
  const timelineRef = useRef(null);
  const previewRef = useRef(null);
  const animationFrameRef = useRef(null);
  const mediaInputRef = useRef(null);
  const audioContextRef = useRef(null);
  const exportCanvasRef = useRef(null);

  // Initialize libraries
  useEffect(() => {
    // Effects Library
    setEffectsLibrary([
      { id: 1, name: 'Glitch', category: 'Distortion', preview: '📺', intensity: 50 },
      { id: 2, name: 'Vintage', category: 'Style', preview: '📼', intensity: 50 },
      { id: 3, name: 'Vignette', category: 'Light', preview: '🔆', intensity: 30 },
      { id: 4, name: 'Film Grain', category: 'Texture', preview: '🎞️', intensity: 20 },
      { id: 5, name: 'Chromatic', category: 'Distortion', preview: '🌈', intensity: 25 },
      { id: 6, name: 'Bloom', category: 'Light', preview: '✨', intensity: 40 },
      { id: 7, name: 'Sharpen', category: 'Enhance', preview: '🔍', intensity: 30 },
      { id: 8, name: 'Blur', category: 'Enhance', preview: '💫', intensity: 50 },
      { id: 9, name: 'Pixelate', category: 'Distortion', preview: '🔲', intensity: 60 },
      { id: 10, name: 'Mirror', category: 'Distortion', preview: '🪞', intensity: 100 },
    ]);

    // Transitions Library
    setTransitionsLibrary([
      { id: 1, name: 'Cross Dissolve', duration: 0.5, category: 'Basic' },
      { id: 2, name: 'Fade to Black', duration: 0.5, category: 'Basic' },
      { id: 3, name: 'Fade to White', duration: 0.5, category: 'Basic' },
      { id: 4, name: 'Slide Left', duration: 0.5, category: 'Slide' },
      { id: 5, name: 'Slide Right', duration: 0.5, category: 'Slide' },
      { id: 6, name: 'Slide Up', duration: 0.5, category: 'Slide' },
      { id: 7, name: 'Slide Down', duration: 0.5, category: 'Slide' },
      { id: 8, name: 'Zoom In', duration: 0.5, category: 'Zoom' },
      { id: 9, name: 'Zoom Out', duration: 0.5, category: 'Zoom' },
      { id: 10, name: 'Wipe Left', duration: 0.5, category: 'Wipe' },
      { id: 11, name: 'Wipe Right', duration: 0.5, category: 'Wipe' },
      { id: 12, name: 'Circle Open', duration: 0.5, category: 'Shape' },
      { id: 13, name: 'Circle Close', duration: 0.5, category: 'Shape' },
      { id: 14, name: 'Heart', duration: 0.5, category: 'Shape' },
      { id: 15, name: 'Star', duration: 0.5, category: 'Shape' },
    ]);

    // Text Templates
    setTextTemplates([
      { id: 1, name: 'Title Bold', style: 'font-bold text-4xl', bg: 'gradient-purple' },
      { id: 2, name: 'Subtitle', style: 'font-medium text-2xl', bg: 'gradient-blue' },
      { id: 3, name: 'Lower Third', style: 'font-normal text-lg', bg: 'gradient-green' },
      { id: 4, name: 'Caption', style: 'font-light text-base', bg: 'gradient-orange' },
      { id: 5, name: 'Credit', style: 'font-thin text-sm', bg: 'gradient-pink' },
      { id: 6, name: 'Quote', style: 'font-italic text-xl', bg: 'gradient-cyan' },
    ]);

    // Filters
    setFilters([
      { id: 1, name: 'Normal', filter: 'none', category: 'Basic' },
      { id: 2, name: 'Cinema', filter: 'contrast(1.1) saturate(1.2) brightness(0.95)', category: 'Style' },
      { id: 3, name: 'Vintage', filter: 'sepia(0.4) contrast(0.9) brightness(1.05)', category: 'Style' },
      { id: 4, name: 'Cool', filter: 'hue-rotate(180deg) saturate(0.8)', category: 'Color' },
      { id: 5, name: 'Warm', filter: 'sepia(0.2) saturate(1.3)', category: 'Color' },
      { id: 6, name: 'B&W', filter: 'grayscale(1)', category: 'Color' },
      { id: 7, name: 'Vivid', filter: 'saturate(1.5) contrast(1.1)', category: 'Enhance' },
      { id: 8, name: 'Dramatic', filter: 'contrast(1.4) brightness(0.9)', category: 'Enhance' },
      { id: 9, name: 'Fade', filter: 'brightness(1.1) contrast(0.85)', category: 'Style' },
      { id: 10, name: 'Matrix', filter: 'hue-rotate(90deg) saturate(2)', category: 'Style' },
      { id: 11, name: 'Night', filter: 'brightness(0.7) contrast(1.2) saturate(0.8)', category: 'Style' },
      { id: 12, name: 'Day', filter: 'brightness(1.15) saturate(1.1)', category: 'Style' },
    ]);

    // Load saved project
    loadProject();
  }, []);

  // Playback animation
  useEffect(() => {
    if (timeline.isPlaying) {
      const animate = () => {
        setTimeline(prev => {
          const newPlayhead = prev.playhead + (1 / project.fps) * prev.playbackRate;
          if (newPlayhead >= project.duration) {
            if (prev.loop) {
              return { ...prev, playhead: 0 };
            } else {
              return { ...prev, playhead: project.duration, isPlaying: false };
            }
          }
          return { ...prev, playhead: newPlayhead };
        });
        animationFrameRef.current = requestAnimationFrame(animate);
      };
      animationFrameRef.current = requestAnimationFrame(animate);
    } else {
      if (animationFrameRef.current) {
        cancelAnimationFrame(animationFrameRef.current);
      }
    }

    return () => {
      if (animationFrameRef.current) {
        cancelAnimationFrame(animationFrameRef.current);
      }
    };
  }, [timeline.isPlaying, project.duration, project.fps, timeline.playbackRate, timeline.loop]);

  // Keyboard shortcuts
  useEffect(() => {
    const handleKeyDown = (e) => {
      // Don't trigger shortcuts when typing in inputs
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

      if (e.ctrlKey || e.metaKey) {
        switch (e.key.toLowerCase()) {
          case 'z':
            e.preventDefault();
            if (e.shiftKey) redo(); else undo();
            break;
          case 'y':
            e.preventDefault();
            redo();
            break;
          case 's':
            e.preventDefault();
            saveProject();
            break;
          case 'e':
            e.preventDefault();
            setShowExport(true);
            break;
          case 'i':
            e.preventDefault();
            setSplitPoint(timeline.playhead);
            break;
          case 'o':
            e.preventDefault();
            setSplitPoint(null);
            break;
          case 'm':
            e.preventDefault();
            toggleMute();
            break;
          case 'b':
            e.preventDefault();
            splitClip();
            break;
          case 'delete':
          case 'backspace':
            e.preventDefault();
            deleteSelected();
            break;
          case ' ':
            e.preventDefault();
            togglePlay();
            break;
          case 'arrowleft':
            e.preventDefault();
            seek(-1);
            break;
          case 'arrowright':
            e.preventDefault();
            seek(1);
            break;
          default:
            break;
        }
      } else {
        switch (e.key.toLowerCase()) {
          case ' ':
            e.preventDefault();
            togglePlay();
            break;
          case 'j':
            e.preventDefault();
            setTimeline(prev => ({ ...prev, playbackRate: 0.5 }));
            break;
          case 'k':
            e.preventDefault();
            setTimeline(prev => ({ ...prev, playbackRate: 1 }));
            break;
          case 'l':
            e.preventDefault();
            setTimeline(prev => ({ ...prev, playbackRate: 2 }));
            break;
          default:
            break;
        }
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, [timeline.playhead, selectedClip]);

  // Save to history
  const saveToHistory = useCallback((newState) => {
    setHistory(prev => {
      const newHistory = prev.slice(0, historyIndex + 1);
      newHistory.push(JSON.parse(JSON.stringify(newState)));
      return newHistory.slice(-100);
    });
    setHistoryIndex(prev => Math.min(prev + 1, 99));
  }, [historyIndex]);

  // Undo
  const undo = () => {
    if (historyIndex > 0) {
      setHistoryIndex(prev => prev - 1);
      const prevState = history[historyIndex - 1];
      if (prevState) {
        setTracks(prevState.tracks || tracks);
        setProject(prevState.project || project);
        setAppliedFilters(prevState.appliedFilters || []);
        setColorGrading(prevState.colorGrading || colorGrading);
        showNotification('Undo successful', 'info');
      }
    } else {
      showNotification('Nothing to undo', 'warning');
    }
  };

  // Redo
  const redo = () => {
    if (historyIndex < history.length - 1) {
      setHistoryIndex(prev => prev + 1);
      const nextState = history[historyIndex + 1];
      if (nextState) {
        setTracks(nextState.tracks || tracks);
        setProject(nextState.project || project);
        setAppliedFilters(nextState.appliedFilters || []);
        setColorGrading(nextState.colorGrading || colorGrading);
        showNotification('Redo successful', 'info');
      }
    } else {
      showNotification('Nothing to redo', 'warning');
    }
  };

  // Show notification
  const showNotification = (message, type = 'info') => {
    setNotification({ message, type });
    setTimeout(() => setNotification(null), 3000);
  };

  // Toggle play
  const togglePlay = () => {
    setTimeline(prev => ({ ...prev, isPlaying: !prev.isPlaying }));
  };

  // Seek
  const seek = (seconds) => {
    setTimeline(prev => ({
      ...prev,
      playhead: Math.max(0, Math.min(project.duration, prev.playhead + seconds)),
    }));
  };

  // Handle timeline click
  const handleTimelineClick = (e) => {
    if (timelineRef.current && !trimmingClip) {
      const rect = timelineRef.current.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const pixelsPerSecond = (rect.width / project.duration) * (timeline.zoom / 100);
      const newPlayhead = Math.max(0, Math.min(project.duration, x / pixelsPerSecond));
      setTimeline(prev => ({ ...prev, playhead: newPlayhead }));
    }
  };

  // Handle media upload
  const handleMediaUpload = (e) => {
    const files = Array.from(e.target.files);
    files.forEach(file => {
      const url = URL.createObjectURL(file);
      const newMedia = {
        id: Date.now() + Math.random(),
        name: file.name,
        type: file.type.startsWith('video') ? 'video' : 'audio',
        url,
        duration: 0,
        thumbnail: null,
      };
      
      if (file.type.startsWith('video')) {
        const video = document.createElement('video');
        video.src = url;
        video.onloadedmetadata = () => {
          newMedia.duration = video.duration;
          newMedia.thumbnail = video;
          setMediaLibrary(prev => [...prev, newMedia]);
          showNotification(`${file.name} added to media library`, 'success');
        };
      } else {
        setMediaLibrary(prev => [...prev, newMedia]);
        showNotification(`${file.name} added to media library`, 'success');
      }
    });
  };

  // Add clip to track
  const addClipToTrack = (media, trackId, startTime = null) => {
    const track = tracks.find(t => t.id === trackId);
    if (!track) return;

    const start = startTime !== null ? startTime : timeline.playhead;
    const newClip = {
      id: Date.now() + Math.random(),
      mediaId: media.id,
      name: media.name,
      start,
      duration: Math.min(media.duration || 10, project.duration - start),
      offset: 0,
      volume: 100,
      effects: [],
      transition: null,
      color: track.type === 'video' ? 'bg-purple-500' : track.type === 'audio' ? 'bg-green-500' : 'bg-blue-500',
    };

    const newTracks = tracks.map(t => {
      if (t.id === trackId) {
        return { ...t, clips: [...t.clips, newClip] };
      }
      return t;
    });

    setTracks(newTracks);
    saveToHistory({ tracks: newTracks });
    showNotification('Clip added to timeline', 'success');
  };

  // Delete selected clip
  const deleteSelected = () => {
    if (!selectedClip) {
      showNotification('No clip selected', 'warning');
      return;
    }

    const newTracks = tracks.map(track => ({
      ...track,
      clips: track.clips.filter(clip => clip.id !== selectedClip),
    }));

    setTracks(newTracks);
    saveToHistory({ tracks: newTracks });
    setSelectedClip(null);
    showNotification('Clip deleted', 'info');
  };

  // Split clip at playhead
  const splitClip = () => {
    if (!selectedClip) {
      showNotification('No clip selected', 'warning');
      return;
    }

    const track = tracks.find(t => t.clips.some(c => c.id === selectedClip));
    if (!track) return;

    const clip = track.clips.find(c => c.id === selectedClip);
    if (!clip) return;

    if (timeline.playhead <= clip.start || timeline.playhead >= clip.start + clip.duration) {
      showNotification('Playhead must be within clip', 'warning');
      return;
    }

    const splitPoint = timeline.playhead - clip.start;
    const firstPart = { ...clip, duration: splitPoint };
    const secondPart = {
      ...clip,
      id: Date.now() + Math.random(),
      start: clip.start + splitPoint,
      duration: clip.duration - splitPoint,
      offset: clip.offset + splitPoint,
      name: `${clip.name} (2)`,
    };

    const newTracks = tracks.map(t => {
      if (t.id === track.id) {
        return {
          ...t,
          clips: [...t.clips.filter(c => c.id !== selectedClip), firstPart, secondPart],
        };
      }
      return t;
    });

    setTracks(newTracks);
    saveToHistory({ tracks: newTracks });
    setSelectedClip(secondPart.id);
    showNotification('Clip split', 'success');
  };

  // Toggle mute
  const toggleMute = () => {
    if (!selectedTrack) {
      showNotification('Select a track first', 'warning');
      return;
    }

    const newTracks = tracks.map(t => {
      if (t.id === selectedTrack) {
        return { ...t, muted: !t.muted };
      }
      return t;
    });

    setTracks(newTracks);
    saveToHistory({ tracks: newTracks });
    showNotification(`Track ${newTracks.find(t => t.id === selectedTrack)?.muted ? 'muted' : 'unmuted'}`, 'info');
  };

  // Save project
  const saveProject = () => {
    const projectData = {
      project,
      tracks,
      appliedFilters,
      colorGrading,
      audioLevels,
      savedAt: new Date().toISOString(),
    };

    try {
      localStorage.setItem('videoEditorProject', JSON.stringify(projectData));
      showNotification('Project saved successfully', 'success');
    } catch (error) {
      showNotification('Failed to save project', 'error');
      console.error('Save error:', error);
    }
  };

  // Load project
  const loadProject = () => {
    try {
      const saved = localStorage.getItem('videoEditorProject');
      if (saved) {
        const projectData = JSON.parse(saved);
        setProject(projectData.project || project);
        setTracks(projectData.tracks || tracks);
        setAppliedFilters(projectData.appliedFilters || []);
        setColorGrading(projectData.colorGrading || colorGrading);
        setAudioLevels(projectData.audioLevels || audioLevels);
        showNotification('Project loaded successfully', 'success');
      }
    } catch (error) {
      showNotification('Failed to load project', 'error');
      console.error('Load error:', error);
    }
  };

  // Export video
  const handleExport = async () => {
    setShowExport(true);
    setIsExporting(true);
    setExportProgress(0);

    try {
      // Simulate export process
      const exportInterval = setInterval(() => {
        setExportProgress(prev => {
          if (prev >= 100) {
            clearInterval(exportInterval);
            setIsExporting(false);
            showNotification('Export completed!', 'success');
            return 100;
          }
          return prev + Math.random() * 5 + 2;
        });
      }, 200);
    } catch (error) {
      setIsExporting(false);
      showNotification('Export failed', 'error');
      console.error('Export error:', error);
    }
  };

  // Get combined filter style
  const getCombinedFilter = () => {
    let filter = 'none';
    
    // Applied filter
    if (appliedFilters.length > 0) {
      const filterObj = filters.find(f => f.id === appliedFilters[0]);
      if (filterObj) filter = filterObj.filter;
    }

    // Color grading adjustments
    const adjustments = [
      `brightness(${colorGrading.brightness}%)`,
      `contrast(${colorGrading.contrast}%)`,
      `saturate(${colorGrading.saturation}%)`,
    ];

    return filter === 'none' ? adjustments.join(' ') : `${filter} ${adjustments.join(' ')}`;
  };

  // Format time
  const formatTime = (seconds) => {
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    const frames = Math.floor((seconds % 1) * project.fps);
    return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}:${frames.toString().padStart(2, '0')}`;
  };

  // Get all clips
  const getAllClips = () => {
    return tracks.flatMap(track => track.clips.map(clip => ({ ...clip, trackId: track.id, trackType: track.type })));
  };

  // Drag handlers
  const handleDragStart = (item, type) => {
    setDraggedItem({ item, type });
  };

  const handleDrop = (e, trackId, clipIndex = null) => {
    e.preventDefault();
    if (!draggedItem) return;

    if (draggedItem.type === 'media') {
      addClipToTrack(draggedItem.item, trackId);
    } else if (draggedItem.type === 'effect') {
      // Apply effect to selected clip
      if (selectedClip) {
        const newTracks = tracks.map(track => ({
          ...track,
          clips: track.clips.map(clip => {
            if (clip.id === selectedClip) {
              return { ...clip, effects: [...clip.effects, draggedItem.item.id] };
            }
            return clip;
          }),
        }));
        setTracks(newTracks);
        saveToHistory({ tracks: newTracks });
        showNotification(`Effect "${draggedItem.item.name}" applied`, 'success');
      }
    } else if (draggedItem.type === 'transition') {
      // Apply transition between clips
      if (selectedClip) {
        const newTracks = tracks.map(track => ({
          ...track,
          clips: track.clips.map(clip => {
            if (clip.id === selectedClip) {
              return { ...clip, transition: draggedItem.item.id };
            }
            return clip;
          }),
        }));
        setTracks(newTracks);
        saveToHistory({ tracks: newTracks });
        showNotification(`Transition "${draggedItem.item.name}" applied`, 'success');
      }
    }

    setDraggedItem(null);
  };

  const handleDragOver = (e) => {
    e.preventDefault();
  };

  return (
    <div className="h-screen bg-gray-950 text-white overflow-hidden flex flex-col">
      {/* Notification Toast */}
      <AnimatePresence>
        {notification && (
          <motion.div
            initial={{ opacity: 0, y: -50, x: '-50%' }}
            animate={{ opacity: 1, y: 0, x: '-50%' }}
            exit={{ opacity: 0, y: -50, x: '-50%' }}
            className={`fixed top-4 left-1/2 z-50 px-6 py-3 rounded-lg shadow-lg ${
              notification.type === 'success' ? 'bg-green-600' :
              notification.type === 'error' ? 'bg-red-600' :
              notification.type === 'warning' ? 'bg-yellow-600' :
              'bg-blue-600'
            }`}
          >
            <div className="flex items-center space-x-2">
              <span>{notification.type === 'success' ? '✅' : notification.type === 'error' ? '❌' : notification.type === 'warning' ? '⚠️' : 'ℹ️'}</span>
              <span className="font-medium">{notification.message}</span>
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* Top Bar */}
      <header className="bg-gray-900 border-b border-gray-800 px-4 py-2 flex items-center justify-between">
        <div className="flex items-center space-x-4">
          <motion.div 
            className="text-xl font-bold bg-gradient-to-r from-purple-400 via-pink-400 to-cyan-400 bg-clip-text text-transparent"
            initial={{ opacity: 0, x: -20 }}
            animate={{ opacity: 1, x: 0 }}
          >
            Sufi Video Edit Pro
          </motion.div>
          
          {/* Workspace Tabs */}
          <div className="flex items-center space-x-1 ml-8">
            {workspaces.map(ws => (
              <motion.button
                key={ws.id}
                whileHover={{ scale: 1.05 }}
                whileTap={{ scale: 0.95 }}
                onClick={() => setCurrentWorkspace(ws.id)}
                className={`px-4 py-2 rounded-lg text-sm font-medium transition-all ${
                  currentWorkspace === ws.id 
                    ? 'bg-purple-600 text-white' 
                    : 'bg-gray-800 text-gray-400 hover:bg-gray-700'
                }`}
              >
                <span className="mr-2">{ws.icon}</span>
                {ws.name}
              </motion.button>
            ))}
          </div>
        </div>

        <div className="flex items-center space-x-3">
          <motion.button
            whileHover={{ scale: 1.05 }}
            whileTap={{ scale: 0.95 }}
