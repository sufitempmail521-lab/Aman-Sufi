        <aside className="w-72 bg-gray-900 border-l border-gray-800 flex flex-col">
          {/* Panel Tabs */}
          <div className="flex border-b border-gray-800">
            {['inspector', 'color', 'audio'].map(panel => (
              <button
                key={panel}
                onClick={() => {
                  if (panel === 'color') setShowColorPanel(!showColorPanel);
                  if (panel === 'audio') setShowAudioPanel(!showAudioPanel);
                  setActivePanel(panel);
                }}
                className={`flex-1 py-3 text-sm font-medium transition-colors ${
                  activePanel === panel 
                    ? 'text-purple-400 border-b-2 border-purple-400' 
                    : 'text-gray-400 hover:text-white'
                }`}
              >
                {panel.charAt(0).toUpperCase() + panel.slice(1)}
              </button>
            ))}
          </div>

          {/* Panel Content */}
          <div className="flex-1 overflow-y-auto p-4">
            <AnimatePresence mode="wait">
              {activePanel === 'inspector' && (
                <motion.div
                  key="inspector"
                  initial={{ opacity: 0, x: 20 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -20 }}
                  className="space-y-6"
                >
                  {/* Clip Properties */}
                  <div>
                    <h4 className="text-xs font-semibold text-gray-400 mb-3">CLIP PROPERTIES</h4>
                    {selectedClip ? (
                      (() => {
                        const track = tracks.find(t => t.clips.some(c => c.id === selectedClip));
                        const clip = track?.clips.find(c => c.id === selectedClip);
                        if (!clip) return <p className="text-sm text-gray-500">Clip not found</p>;
                        
                        return (
                          <div className="space-y-3">
                            <div>
                              <label className="text-xs text-gray-400 block mb-1">Name</label>
                              <input
                                type="text"
                                value={clip.name}
                                onChange={(e) => {
                                  const newTracks = tracks.map(t => ({
                                    ...t,
                                    clips: t.clips.map(c => c.id === selectedClip ? { ...c, name: e.target.value } : c),
                                  }));
                                  setTracks(newTracks);
                                }}
                                className="w-full bg-gray-800 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                              />
                            </div>
                            <div>
                              <label className="text-xs text-gray-400 block mb-1">Start (s)</label>
                              <input
                                type="number"
                                min="0"
                                step="0.1"
                                value={clip.start.toFixed(1)}
                                onChange={(e) => {
                                  const newTracks = tracks.map(t => ({
                                    ...t,
                                    clips: t.clips.map(c => c.id === selectedClip ? { ...c, start: Number(e.target.value) } : c),
                                  }));
                                  setTracks(newTracks);
                                  saveToHistory({ tracks: newTracks });
                                }}
                                className="w-full bg-gray-800 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                              />
                            </div>
                            <div>
                              <label className="text-xs text-gray-400 block mb-1">Duration (s)</label>
                              <input
                                type="number"
                                min="0.1"
                                step="0.1"
                                value={clip.duration.toFixed(1)}
                                onChange={(e) => {
                                  const newTracks = tracks.map(t => ({
                                    ...t,
                                    clips: t.clips.map(c => c.id === selectedClip ? { ...c, duration: Number(e.target.value) } : c),
                                  }));
                                  setTracks(newTracks);
                                  saveToHistory({ tracks: newTracks });
                                }}
                                className="w-full bg-gray-800 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                              />
                            </div>
                            <div>
                              <label className="text-xs text-gray-400 block mb-1">Volume</label>
                              <input
                                type="range"
                                min="0"
                                max="100"
                                value={clip.volume || 100}
                                onChange={(e) => {
                                  const newTracks = tracks.map(t => ({
                                    ...t,
                                    clips: t.clips.map(c => c.id === selectedClip ? { ...c, volume: Number(e.target.value) } : c),
                                  }));
                                  setTracks(newTracks);
                                }}
                                className="w-full accent-purple-500"
                              />
                              <span className="text-xs text-gray-400">{clip.volume || 100}%</span>
                            </div>
                          </div>
                        );
                      })()
                    ) : (
                      <p className="text-sm text-gray-500">Select a clip to edit properties</p>
                    )}
                  </div>

                  {/* Project Settings */}
                  <div>
                    <h4 className="text-xs font-semibold text-gray-400 mb-3">PROJECT SETTINGS</h4>
                    <div className="space-y-3">
                      <div>
                        <label className="text-xs text-gray-400 block mb-1">Project Name</label>
                        <input
                          type="text"
                          value={project.name}
                          onChange={(e) => setProject(prev => ({ ...prev, name: e.target.value }))}
                          className="w-full bg-gray-800 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                        />
                      </div>
                      <div>
                        <label className="text-xs text-gray-400 block mb-1">Duration (s)</label>
                        <input
                          type="number"
                          min="1"
                          value={project.duration}
                          onChange={(e) => setProject(prev => ({ ...prev, duration: Number(e.target.value) }))}
                          className="w-full bg-gray-800 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                        />
                      </div>
                      <div>
                        <label className="text-xs text-gray-400 block mb-1">Resolution</label>
                        <select
                          value={`${project.width}x${project.height}`}
                          onChange={(e) => {
                            const [w, h] = e.target.value.split('x').map(Number);
                            setProject(prev => ({ ...prev, width: w, height: h }));
                          }}
                          className="w-full bg-gray-800 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                        >
                          <option value="1920x1080">1080p (1920x1080)</option>
                          <option value="3840x2160">4K (3840x2160)</option>
                          <option value="1280x720">720p (1280x720)</option>
                          <option value="854x480">480p (854x480)</option>
                        </select>
                      </div>
                      <div>
                        <label className="text-xs text-gray-400 block mb-1">Frame Rate</label>
                        <select
                          value={project.fps}
                          onChange={(e) => setProject(prev => ({ ...prev, fps: Number(e.target.value) }))}
                          className="w-full bg-gray-800 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                        >
                          <option value="24">24 fps</option>
                          <option value="30">30 fps</option>
                          <option value="60">60 fps</option>
                        </select>
                      </div>
                    </div>
                  </div>

                  {/* Filters */}
                  <div>
                    <h4 className="text-xs font-semibold text-gray-400 mb-3">FILTERS</h4>
                    <div className="grid grid-cols-2 gap-2">
                      {filters.map(filter => (
                        <motion.button
                          key={filter.id}
                          whileHover={{ scale: 1.05 }}
                          whileTap={{ scale: 0.95 }}
                          onClick={() => {
                            if (appliedFilters.includes(filter.id)) {
                              setAppliedFilters([]);
                            } else {
                              setAppliedFilters([filter.id]);
                            }
                          }}
                          className={`p-2 rounded-lg text-xs transition-all ${
                            appliedFilters.includes(filter.id)
                              ? 'bg-purple-600 text-white'
                              : 'bg-gray-800 hover:bg-gray-700'
                          }`}
                        >
                          <div 
                            className="w-full h-8 rounded mb-1"
                            style={{ 
                              background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
                              filter: filter.filter
                            }}
                          />
                          {filter.name}
                        </motion.button>
                      ))}
                    </div>
                  </div>
                </motion.div>
              )}

              {activePanel === 'color' && (
                <motion.div
                  key="color"
                  initial={{ opacity: 0, x: 20 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -20 }}
                  className="space-y-4"
                >
                  <h4 className="text-xs font-semibold text-gray-400">COLOR GRADING</h4>
                  <div className="space-y-3">
                    {Object.entries(colorGrading).map(([key, value]) => (
                      <div key={key}>
                        <label className="text-xs text-gray-400 block mb-1 capitalize">{key}</label>
                        <input
                          type="range"
                          min={key === 'temperature' || key === 'tint' ? -100 : 0}
                          max={key === 'temperature' || key === 'tint' ? 100 : 200}
                          value={value}
                          onChange={(e) => setColorGrading(prev => ({ ...prev, [key]: Number(e.target.value) }))}
                          className="w-full accent-purple-500"
                        />
                        <div className="flex justify-between text-xs text-gray-500">
                          <span>{key === 'temperature' || key === 'tint' ? -100 : 0}</span>
                          <span>{value}</span>
                          <span>{key === 'temperature' || key === 'tint' ? 100 : 200}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                  <motion.button
                    whileHover={{ scale: 1.02 }}
                    whileTap={{ scale: 0.98 }}
                    onClick={() => setColorGrading({
                      brightness: 100,
                      contrast: 100,
                      saturation: 100,
                      temperature: 0,
                      tint: 0,
                      highlights: 0,
                      shadows: 0,
                      whites: 0,
                      blacks: 0,
                    })}
                    className="w-full py-2 bg-gray-800 hover:bg-gray-700 rounded-lg text-sm transition-colors"
                  >
                    Reset Color Grading
                  </motion.button>
                </motion.div>
              )}

              {activePanel === 'audio' && (
                <motion.div
                  key="audio"
                  initial={{ opacity: 0, x: 20 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -20 }}
                  className="space-y-4"
                >
                  <h4 className="text-xs font-semibold text-gray-400">AUDIO MIXER</h4>
                  <div className="space-y-4">
                    {Object.entries(audioLevels).map(([key, value]) => (
                      <div key={key}>
                        <label className="text-xs text-gray-400 block mb-1 capitalize">{key}</label>
                        <input
                          type="range"
                          min="0"
                          max="100"
                          value={value}
                          onChange={(e) => setAudioLevels(prev => ({ ...prev, [key]: Number(e.target.value) }))}
                          className="w-full accent-purple-500"
                        />
                        <span className="text-xs text-gray-500">{value}%</span>
                      </div>
                    ))}
                  </div>

                  <h4 className="text-xs font-semibold text-gray-400 pt-4">AUDIO EFFECTS</h4>
                  <div className="space-y-2">
                    {['Noise Reduction', 'EQ', 'Compressor', 'Reverb', 'Delay', 'Normalize'].map(effect => (
                      <motion.button
                        key={effect}
                        whileHover={{ x: 5 }}
                        className="w-full p-3 bg-gray-800 hover:bg-gray-700 rounded-lg text-left text-sm transition-colors flex items-center justify-between"
                      >
                        <span>{effect}</span>
                        <input type="checkbox" className="accent-purple-500" />
                      </motion.button>
                    ))}
                  </div>
                </motion.div>
              )}
            </AnimatePresence>
          </div>
        </aside>
      </div>

      {/* Export Modal */}
      <AnimatePresence>
        {showExport && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50"
            onClick={() => !isExporting && setShowExport(false)}
          >
            <motion.div
              initial={{ scale: 0.9, opacity: 0 }}
              animate={{ scale: 1, opacity: 1 }}
              exit={{ scale: 0.9, opacity: 0 }}
              className="bg-gray-900 rounded-xl p-8 max-w-lg w-full mx-4 border border-gray-800"
              onClick={(e) => e.stopPropagation()}
            >
              <h3 className="text-2xl font-bold mb-6">
                {isExporting ? '🎬 Exporting Video...' : exportProgress >= 100 ? '✅ Export Complete!' : '📤 Export Video'}
              </h3>
              
              {isExporting ? (
                <div className="space-y-4">
                  <div className="w-full bg-gray-800 rounded-full h-6 overflow-hidden">
                    <motion.div
                      className="h-full bg-gradient-to-r from-purple-600 to-pink-600"
                      style={{ width: `${Math.min(100, exportProgress)}%` }}
                    />
                  </div>
                  <p className="text-center text-gray-400">{Math.round(Math.min(100, exportProgress))}% Complete</p>
                  <p className="text-sm text-gray-500 text-center">
                    Rendering your video... Please wait.
                  </p>
                </div>
              ) : exportProgress >= 100 ? (
                <div className="space-y-4">
                  <div className="bg-gray-800 rounded-lg p-4">
                    <h4 className="font-medium mb-3">Export Summary</h4>
                    <div className="space-y-2 text-sm">
                      <div className="flex justify-between">
                        <span className="text-gray-400">File Size:</span>
                        <span>~{Math.round(project.duration * 2.5)} MB</span>
                      </div>
                      <div className="flex justify-between">
                        <span className="text-gray-400">Duration:</span>
                        <span>{formatTime(project.duration)}</span>
                      </div>
                      <div className="flex justify-between">
                        <span className="text-gray-400">Resolution:</span>
                        <span>{project.width}x{project.height}</span>
                      </div>
                      <div className="flex justify-between">
                        <span className="text-gray-400">Frame Rate:</span>
                        <span>{project.fps} fps</span>
                      </div>
                    </div>
                  </div>
                  <div className="flex space-x-3">
                    <motion.button
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                      onClick={() => {
                        setShowExport(false);
                        setExportProgress(0);
                      }}
                      className="flex-1 py-3 bg-gray-800 hover:bg-gray-700 rounded-lg transition-colors"
                    >
                      Close
                    </motion.button>
                    <motion.button
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                      onClick={() => {
                        showNotification('Download started...', 'success');
                        setTimeout(() => {
                          setShowExport(false);
                          setExportProgress(0);
                        }, 1000);
                      }}
                      className="flex-1 py-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 rounded-lg transition-colors"
                    >
                      Download
                    </motion.button>
                  </div>
                </div>
              ) : (
                <div className="space-y-4">
                  <div className="bg-gray-800 rounded-lg p-4">
                    <h4 className="font-medium mb-3">Export Settings</h4>
                    <div className="space-y-3">
                      <div>
                        <label className="text-xs text-gray-400 block mb-1">Format</label>
                        <select className="w-full bg-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500">
                          <option>MP4 (H.264)</option>
                          <option>MOV (ProRes)</option>
                          <option>WebM (VP9)</option>
                          <option>AVI</option>
                        </select>
                      </div>
                      <div>
                        <label className="text-xs text-gray-400 block mb-1">Quality</label>
                        <select className="w-full bg-gray-700 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500">
                          <option>High (Recommended)</option>
                          <option>Medium</option>
                          <option>Low</option>
                        </select>
                      </div>
                    </div>
                  </div>
                  <div className="flex space-x-3">
                    <motion.button
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                      onClick={() => setShowExport(false)}
                      className="flex-1 py-3 bg-gray-800 hover:bg-gray-700 rounded-lg transition-colors"
                    >
                      Cancel
                    </motion.button>
                    <motion.button
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                      onClick={handleExport}
                      className="flex-1 py-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 rounded-lg transition-colors"
                    >
                      Start Export
                    </motion.button>
                  </div>
                </div>
              )}
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* Settings Modal */}
      <AnimatePresence>
        {showSettings && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50"
            onClick={() => setShowSettings(false)}
          >
            <motion.div
              initial={{ scale: 0.9, opacity: 0 }}
              animate={{ scale: 1, opacity: 1 }}
              exit={{ scale: 0.9, opacity: 0 }}
              className="bg-gray-900 rounded-xl p-6 max-w-md w-full mx-4 border border-gray-800"
              onClick={(e) => e.stopPropagation()}
            >
              <h3 className="text-xl font-bold mb-4">⚙️ Settings</h3>
              <div className="space-y-4">
                <div className="flex items-center justify-between">
                  <span>Auto-Save</span>
                  <input type="checkbox" defaultChecked className="accent-purple-500" />
                </div>
                <div className="flex items-center justify-between">
                  <span>Hardware Acceleration</span>
                  <input type="checkbox" defaultChecked className="accent-purple-500" />
                </div>
                <div className="flex items-center justify-between">
                  <span>Show Waveforms</span>
                  <input type="checkbox" defaultChecked className="accent-purple-500" />
                </div>
                <div className="flex items-center justify-between">
                  <span>Timeline Snap</span>
                  <input type="checkbox" checked={timeline.snapEnabled} onChange={(e) => setTimeline(prev => ({ ...prev, snapEnabled: e.target.checked }))} className="accent-purple-500" />
                </div>
              </div>
              <motion.button
                whileHover={{ scale: 1.02 }}
                whileTap={{ scale: 0.98 }}
                onClick={() => setShowSettings(false)}
                className="mt-6 w-full py-3 bg-purple-600 hover:bg-purple-700 rounded-lg transition-colors"
              >
                Close
              </motion.button>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* Keyboard Shortcuts Modal */}
      <AnimatePresence>
        {showShortcuts && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50"
            onClick={() => setShowShortcuts(false)}
          >
            <motion.div
              initial={{ scale: 0.9, opacity: 0 }}
              animate={{ scale: 1, opacity: 1 }}
              exit={{ scale: 0.9, opacity: 0 }}
              className="bg-gray-900 rounded-xl p-6 max-w-lg w-full mx-4 border border-gray-800"
              onClick={(e) => e.stopPropagation()}
            >
              <h3 className="text-xl font-bold mb-4">⌨️ Keyboard Shortcuts</h3>
              <div className="grid grid-cols-2 gap-4 text-sm">
                <div className="space-y-2">
                  <div className="flex justify-between"><span>Play/Pause</span><span className="text-gray-400">Space</span></div>
                  <div className="flex justify-between"><span>Undo</span><span className="text-gray-400">Ctrl+Z</span></div>
                  <div className="flex justify-between"><span>Redo</span><span className="text-gray-400">Ctrl+Y</span></div>
                  <div className="flex justify-between"><span>Save</span><span className="text-gray-400">Ctrl+S</span></div>
                  <div className="flex justify-between"><span>Export</span><span className="text-gray-400">Ctrl+E</span></div>
                </div>
                <div className="space-y-2">
                  <div className="flex justify-between"><span>Split Clip</span><span className="text-gray-400">B</span></div>
                  <div className="flex justify-between"><span>Delete</span><span className="text-gray-400">Del</span></div>
                  <div className="flex justify-between"><span>Mute Track</span><span className="text-gray-400">M</span></div>
                  <div className="flex justify-between"><span>0.5x Speed</span><span className="text-gray-400">J</span></div>
                  <div className="flex justify-between"><span>2x Speed</span><span className="text-gray-400">L</span></div>
                </div>
              </div>
              <motion.button
                whileHover={{ scale: 1.02 }}
                whileTap={{ scale: 0.98 }}
                onClick={() => setShowShortcuts(false)}
                className="mt-6 w-full py-3 bg-purple-600 hover:bg-purple-700 rounded-lg transition-colors"
              >
                Close
              </motion.button>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
